@* Estado vacío: se muestra cuando la API responde correctamente pero sin registros. *@

<div class="state-panel">
    <div class="state-panel__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M4 7h16M4 12h10M4 17h6" stroke-linecap="round" />
        </svg>
    </div>
    <h3 class="state-panel__title">No hay movimientos para mostrar</h3>
    <p class="state-panel__description">@Mensaje</p>
</div>

@code {
    [Parameter]
    public string Mensaje { get; set; } = "El servicio no reporta registros en este momento.";
}
