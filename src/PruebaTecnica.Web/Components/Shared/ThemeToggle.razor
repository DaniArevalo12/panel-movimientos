@* Selector de tema claro/oscuro. La preferencia se persiste en localStorage vía interop JS. *@
@implements IAsyncDisposable
@inject IJSRuntime JsRuntime

<button type="button"
        class="btn btn--icon"
        title="@(_esOscuro ? "Cambiar a tema claro" : "Cambiar a tema oscuro")"
        aria-label="@(_esOscuro ? "Cambiar a tema claro" : "Cambiar a tema oscuro")"
        @onclick="AlternarTemaAsync">
    @if (_esOscuro)
    {
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
            <circle cx="12" cy="12" r="4.5" />
            <path d="M12 2.5v2M12 19.5v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2.5 12h2M19.5 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" stroke-linecap="round" />
        </svg>
    }
    else
    {
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M20 14.5A8.5 8.5 0 0 1 9.5 4a8.5 8.5 0 1 0 10.5 10.5Z" stroke-linejoin="round" />
        </svg>
    }
</button>

@code {
    private IJSObjectReference? _module;
    private bool _esOscuro;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/theme.js");
        var temaActual = await _module.InvokeAsync<string>("obtenerTema");
        _esOscuro = temaActual == "dark";
        StateHasChanged();
    }

    private async Task AlternarTemaAsync()
    {
        if (_module is null)
        {
            return;
        }

        _esOscuro = !_esOscuro;
        await _module.InvokeVoidAsync("establecerTema", _esOscuro ? "dark" : "light");
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // El circuito ya se cerró (navegación/cierre de pestaña): no hay nada que liberar.
            }
        }
    }
}
