@* Estado de error amigable: se muestra cuando la consulta a la API falla. Nunca expone detalles técnicos crudos. *@

<div class="state-panel state-panel--error">
    <div class="state-panel__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="9" />
            <path d="M12 8v5M12 16h.01" stroke-linecap="round" />
        </svg>
    </div>
    <h3 class="state-panel__title">No se pudieron cargar los movimientos</h3>
    <p class="state-panel__description">@Mensaje</p>
    <button type="button" class="btn btn--primary" @onclick="OnReintentar">
        Reintentar
    </button>
</div>

@code {
    [Parameter, EditorRequired]
    public string Mensaje { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnReintentar { get; set; }
}
